# MyClaw 配置文件示例 (.env.example)
# 复制为 .env 后填写真实密钥: cp .env.example .env

# --- 网关通讯配置 ---
OPENCLAW_GATEWAY_TOKEN="change_me"

# --- 推理模型配置 ---
# 默认使用百炼 qwen3-max
BAILIAN_API_KEY="replace_with_your_bailian_key"
VOLCANO_API_KEY="replace_with_your_volcano_key"

# --- Feishu/Lark 渠道配置 ---
FEISHU_APP_ID="cli_xxx"
FEISHU_APP_SECRET="replace_with_your_feishu_app_secret"
# 国际版租户使用 lark，国内版保持 feishu
FEISHU_DOMAIN="feishu"

# --- 日志 ---
LOG_LEVEL="INFO"
